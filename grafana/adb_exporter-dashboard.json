{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Fleet health for adb_exporter: worst-in-fleet at a glance, a device overview sorted by risk, and trends for the volatile signals.",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["android", "adb", "prometheus"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(android_farm_adb_online, device)",
        "hide": 0,
        "includeAll": true,
        "label": "Device",
        "multi": true,
        "name": "device",
        "options": [],
        "query": "label_values(android_farm_adb_online, device)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "adb_exporter — Android device farm",
  "uid": "adb-exporter",
  "version": 2,
  "panels": [
    {
      "id": 1,
      "title": "Devices online",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "description": "Devices reporting state=device right now.",
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(android_farm_adb_online{device=~\"$device\"})", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Scrapes failing",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "description": "Online devices whose last scrape did not parse. 0 is healthy.",
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(1 - android_farm_adb_scrape_success{device=~\"$device\"})", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Hottest device",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "description": "Highest thermal-zone reading across the selected fleet.",
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 40 }, { "color": "red", "value": 45 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(android_farm_thermal_max_temperature_celsius{device=~\"$device\"})", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Lowest battery",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "description": "Lowest charge level across the selected fleet.",
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 20 }, { "color": "green", "value": 50 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "min(android_farm_battery_level{device=~\"$device\"})", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Device overview — worst first",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "One row per device, sorted so the hottest device is on top. Colour marks where to look.",
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 4 },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [ { "displayName": "Thermal °C", "desc": true } ]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Online" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.width", "value": 90 },
              { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "offline", "color": "red", "index": 0 }, "1": { "text": "online", "color": "green", "index": 1 } } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 0 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 0 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Battery %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 20 }, { "color": "green", "value": 50 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Battery °C" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 38 }, { "color": "red", "value": 43 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Thermal °C" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 40 }, { "color": "red", "value": 45 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Free /data" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 2000000000 }, { "color": "green", "value": 10000000000 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [ { "id": "unit", "value": "s" }, { "id": "decimals", "value": 0 } ]
          }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_adb_online{device=~\"$device\"}", "format": "table", "instant": true, "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_cpu_usage_percent{device=~\"$device\"}", "format": "table", "instant": true, "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_memory_used_percent{device=~\"$device\"}", "format": "table", "instant": true, "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_battery_level{device=~\"$device\"}", "format": "table", "instant": true, "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_battery_temperature_celsius{device=~\"$device\"}", "format": "table", "instant": true, "refId": "E" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_thermal_max_temperature_celsius{device=~\"$device\"}", "format": "table", "instant": true, "refId": "F" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_storage_free_bytes{device=~\"$device\"}", "format": "table", "instant": true, "refId": "G" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_uptime_seconds{device=~\"$device\"}", "format": "table", "instant": true, "refId": "H" }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "device", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true, "Time 7": true, "Time 8": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true, "__name__ 6": true, "__name__ 7": true, "__name__ 8": true
            },
            "indexByName": {
              "device": 0, "Value #A": 1, "Value #F": 2, "Value #E": 3, "Value #B": 4, "Value #C": 5, "Value #D": 6, "Value #G": 7, "Value #H": 8
            },
            "renameByName": {
              "device": "Device",
              "Value #A": "Online",
              "Value #B": "CPU %",
              "Value #C": "Mem %",
              "Value #D": "Battery %",
              "Value #E": "Battery °C",
              "Value #F": "Thermal °C",
              "Value #G": "Free /data",
              "Value #H": "Uptime"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 12, "showPoints": "never", "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_cpu_usage_percent{device=~\"$device\"}", "legendFormat": "{{device}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Memory used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 12, "showPoints": "never", "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_memory_used_percent{device=~\"$device\"}", "legendFormat": "{{device}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "title": "Temperature",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Max thermal-zone temperature per device. Red line marks the 45 °C throttling watch level.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "transparent", "value": null }, { "color": "red", "value": 45 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "android_farm_thermal_max_temperature_celsius{device=~\"$device\"}", "legendFormat": "{{device}}", "refId": "A" }
      ]
    }
  ]
}
